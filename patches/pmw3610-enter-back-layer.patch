diff --git a/Kconfig b/Kconfig
index 8ec6c60..b2b2479 100644
--- a/Kconfig
+++ b/Kconfig
@@ -167,6 +167,19 @@ config PMW3610_MOVEMENT_THRESHOLD
         A higher value means more movement is required to activate the mouse layer.
         This helps prevent accidental activation during typing.
 
+config PMW3610_BACK_LAYER
+    int "Layer activated by longer automatic mouse movement"
+    default -1
+    help
+        Optional extra layer to activate when movement exceeds a higher threshold.
+        This can override only selected keys while the normal automouse layer stays responsive.
+
+config PMW3610_BACK_LAYER_MOVEMENT_THRESHOLD
+    int "Movement threshold for the longer automatic mouse layer"
+    default 10
+    help
+        Trackball movement required to activate PMW3610_BACK_LAYER.
+
 config PMW3610_BALL_ACTION_TICK
     int "PMW3610's required ticks to trigger a ball action"
     default 20
diff --git a/src/pmw3610.c b/src/pmw3610.c
index 3ae949f..a2f6d2a 100644
--- a/src/pmw3610.c
+++ b/src/pmw3610.c
@@ -571,6 +571,21 @@ static void deactivate_automouse_layer(struct k_timer *timer) {
 K_TIMER_DEFINE(automouse_layer_timer, deactivate_automouse_layer, NULL);
 #endif
 
+#if CONFIG_PMW3610_BACK_LAYER >= 0
+struct k_timer automouse_back_layer_timer;
+
+static void activate_automouse_back_layer() {
+    zmk_keymap_layer_activate(CONFIG_PMW3610_BACK_LAYER);
+    k_timer_start(&automouse_back_layer_timer, K_MSEC(CONFIG_PMW3610_AUTOMOUSE_TIMEOUT_MS), K_NO_WAIT);
+}
+
+static void deactivate_automouse_back_layer(struct k_timer *timer) {
+    zmk_keymap_layer_deactivate(CONFIG_PMW3610_BACK_LAYER);
+}
+
+K_TIMER_DEFINE(automouse_back_layer_timer, deactivate_automouse_back_layer, NULL);
+#endif
+
 int ball_action_idx = -1;
 static enum pixart_input_mode get_input_mode_for_current_layer(const struct device *dev) {
     const struct pixart_config *config = dev->config;
@@ -725,6 +740,12 @@ static int pmw3610_report_data(const struct device *dev) {
                 movement_size > CONFIG_PMW3610_MOVEMENT_THRESHOLD) {
                 activate_automouse_layer();
             }
+#if CONFIG_PMW3610_BACK_LAYER >= 0
+            if (input_mode == MOVE &&
+                movement_size > CONFIG_PMW3610_BACK_LAYER_MOVEMENT_THRESHOLD) {
+                activate_automouse_back_layer();
+            }
+#endif
 #endif
             input_report_rel(dev, INPUT_REL_X, x, false, K_FOREVER);
             input_report_rel(dev, INPUT_REL_Y, y, true, K_FOREVER);
